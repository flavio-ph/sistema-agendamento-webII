@model IEnumerable<SistemaAgendamentoWebII.Models.Professional>

@{
    ViewData["Title"] = "Explorar Profissionais";
}

<div class="container py-5" style="max-width: 1200px;">
    <div class="text-center mb-5">
        <h1 class="h2 fw-bold" style="color: var(--ds-text-main, #0b1c30);">Encontre o profissional ideal</h1>
        <p class="text-muted">Explore os nossos especialistas e agende o seu próximo serviço.</p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var prof in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm" style="border-radius: 1rem; transition: transform 0.2s;">
                        <div class="card-body p-4 text-center">
                            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center fw-bold mb-3"
                                 style="width: 80px; height: 80px; font-size: 2rem; color: var(--ds-primary, #00236f);">
                                @(prof.User?.Name?.Substring(0, 1).ToUpper() ?? "P")
                            </div>

                            <h3 class="h5 fw-bold mb-1 text-dark">@prof.User?.Name</h3>
                            <p class="text-muted small mb-3">@(prof.Specialty ?? "Profissional independente")</p>

                            <div class="d-flex justify-content-center gap-2 mb-4">
                                <span class="badge bg-light text-dark border">
                                    ⭐ @prof.AverageRating.ToString("0.0")
                                </span>
                                <span class="badge bg-light text-dark border">
                                    @(prof.ExperienceYears ?? 0) anos exp.
                                </span>
                            </div>

                            <a asp-controller="Professionals" asp-action="Profile" asp-route-id="@prof.Id"
                               class="btn w-100 text-white fw-bold py-2" style="background: var(--ds-primary, #00236f); border-radius: 0.5rem;">
                                Ver Perfil e Agendar
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="p-4 bg-light rounded d-inline-block">
                    <span class="material-symbols-outlined fs-1 text-muted mb-2">Nenhum profissional</span>
                    <p class="text-muted mb-0">Nenhum profissional disponível no momento.</p>
                </div>
            </div>
        }
    </div>
</div>