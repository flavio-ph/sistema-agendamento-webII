@using System.Security.Claims
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Agendify</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SistemaAgendamentoWebII.styles.css" asp-append-version="true" />

    <style>
        :root {
            --ds-bg: #f8f9ff;
            --ds-surface: #ffffff;
            --ds-primary: #00236f;
            --ds-text-main: #0b1c30;
            --ds-text-muted: #444651;
            --ds-border: #e5eeff;
            --ds-shadow-nav: 0 12px 24px -8px rgba(30, 58, 138, 0.05);
        }

        body {
            background-color: var(--ds-bg);
            font-family: 'Inter', sans-serif;
            color: var(--ds-text-main);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .ds-navbar {
            background-color: var(--ds-surface);
            box-shadow: var(--ds-shadow-nav);
            border-bottom: 1px solid var(--ds-border);
            padding-top: 0.75rem;
            padding-bottom: 0.75rem;
        }

        .ds-brand {
            font-family: 'Manrope', sans-serif;
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--ds-primary) !important;
            letter-spacing: -0.02em;
            text-decoration: none;
            transition: opacity 0.2s;
        }

            .ds-brand:hover {
                opacity: 0.85;
            }

        .ds-nav-link {
            font-weight: 500;
            color: var(--ds-text-muted) !important;
            transition: color 0.2s ease, transform 0.2s ease;
            padding: 0.5rem 1rem !important;
        }

            .ds-nav-link:hover {
                color: var(--ds-primary) !important;
                transform: translateY(-1px);
            }

        .ds-btn-primary {
            background: linear-gradient(180deg, #1e3a8a 0%, var(--ds-primary) 100%);
            color: #ffffff !important;
            border: none;
            border-radius: 0.5rem;
            padding: 8px 24px;
            font-weight: 600;
            box-shadow: 0 4px 12px rgba(0, 35, 111, 0.15);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            text-decoration: none;
        }

            .ds-btn-primary:hover {
                transform: scale(1.02);
                box-shadow: 0 6px 16px rgba(0, 35, 111, 0.25);
            }

        .ds-btn-ghost {
            color: var(--ds-text-muted);
            font-weight: 600;
            border-radius: 0.5rem;
            padding: 8px 20px;
            transition: all 0.2s;
            text-decoration: none;
            border: none;
            background: transparent;
        }

            .ds-btn-ghost:hover {
                background-color: #eff4ff;
                color: var(--ds-primary);
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg ds-navbar sticky-top">
            <div class="container">
                <a class="navbar-brand ds-brand" asp-controller="Home" asp-action="Index">
                    Agendify
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarPrincipal" aria-controls="navbarPrincipal" aria-expanded="false" aria-label="Alternar navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarPrincipal">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 mt-3 mt-lg-0 gap-1">
                        <li class="nav-item">
                            <a class="nav-link ds-nav-link" asp-controller="Home" asp-action="Index">Início</a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Cliente"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link ds-nav-link" asp-controller="Dashboard" asp-action="Index">Meus Agendamentos</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link ds-nav-link" asp-controller="Home" asp-action="Explorar">Explorar</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link ds-nav-link" asp-controller="Dashboard" asp-action="MeuPerfil">Meu Perfil</a>
                                </li>
                            }

                            @if (User.IsInRole("Profissional"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link ds-nav-link" asp-controller="Appointments" asp-action="ProfessionalAgenda">Minha Agenda</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link ds-nav-link" asp-controller="Services" asp-action="Create">Meus Serviços</a>
                                </li>
                            }

                            @if (User.IsInRole("Empresa"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link ds-nav-link" asp-controller="Establishments" asp-action="Edit">Editar Empresa</a>
                                </li>
                              
                            }
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-2 mt-3 mt-lg-0">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                <button type="submit" class="ds-btn-ghost">Sair</button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="ds-btn-ghost">Entrar</a>
                            <a asp-controller="Account" asp-action="Register" class="ds-btn-primary">Cadastrar</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container py-4 flex-grow-1" style="max-width: 1440px;">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-4 bg-white mt-auto">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="fw-medium">
                &copy; @DateTime.Now.Year - Agendify
            </div>
            <div>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted" style="transition: color 0.2s;">
                    Política de Privacidade
                </a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>