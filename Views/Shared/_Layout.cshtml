@using System.Security.Claims
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Agendamento</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SistemaAgendamentoWebII.styles.css" asp-append-version="true" />

    <style>
            :root {
                --ds-bg: #f8f9ff;
                --ds-surface: #ffffff;
                --ds-primary: #00236f;
                --ds-text-main: #0b1c30;
                --ds-text-muted: #444651;
                --ds-border: #e5eeff;
                --ds-shadow-nav: 0 12px 24px -8px rgba(30, 58, 138, 0.05);
            }

            body {
                background-color: var(--ds-bg);
                font-family: 'Inter', sans-serif;
                color: var(--ds-text-main);
            }

            /* Navbar Customizada */
            .ds-navbar {
                background-color: var(--ds-surface);
                box-shadow: var(--ds-shadow-nav);
                border-bottom: 1px solid var(--ds-border);
            }

            .ds-brand {
                font-family: 'Manrope', sans-serif;
                font-weight: 800;
                font-size: 1.25rem;
                color: var(--ds-primary) !important;
                letter-spacing: -0.02em;
            }

            .ds-nav-link {
                font-weight: 500;
                color: var(--ds-text-muted) !important;
                transition: color 0.2s ease;
            }

                .ds-nav-link:hover {
                    color: var(--ds-primary) !important;
                }

            /* Botões */
            .ds-btn-primary {
                background: linear-gradient(180deg, #1e3a8a 0%, var(--ds-primary) 100%);
                color: #ffffff !important;
                border: none;
                border-radius: 0.5rem; /* 8px */
                padding: 8px 20px;
                font-weight: 600;
                box-shadow: 0 4px 12px rgba(0, 35, 111, 0.15);
                transition: transform 0.2s ease, box-shadow 0.2s ease;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
            }

                .ds-btn-primary:hover {
                    transform: scale(1.02);
                    box-shadow: 0 6px 16px rgba(0, 35, 111, 0.25);
                }

            .ds-btn-ghost {
                color: var(--ds-text-muted);
                font-weight: 600;
                border-radius: 0.5rem;
                padding: 8px 16px;
                transition: all 0.2s;
                text-decoration: none;
            }

                .ds-btn-ghost:hover {
                    background-color: #eff4ff;
                    color: var(--ds-primary);
                }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light ds-navbar">
            <div class="container">
                <a class="navbar-brand ds-brand" asp-controller="Home" asp-action="Index">Agendify</a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Alternar navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Cliente"))
                            {
                                <li class="nav-item"><a class="nav-link ds-nav-link" asp-controller="Dashboard" asp-action="Index">Meus Agendamentos</a></li>
                                <li class="nav-item"><a class="nav-link ds-nav-link" asp-controller="Home" asp-action="Explorar">Explorar</a></li>
                            }

                            else if (User.IsInRole("Profissional"))
                            {
                                <li class="nav-item"><a class="nav-link ds-nav-link" asp-controller="Dashboard" asp-action="DashboardProfissional">Agenda</a></li>
                                <li class="nav-item"><a class="nav-link ds-nav-link" asp-controller="Services" asp-action="Create">Meus Serviços</a></li>

                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle ds-nav-link" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        Meu Perfil
                                    </a>
                                    <ul class="dropdown-menu border-0 shadow-sm" aria-labelledby="navbarDropdown">
                                        <li>
                                            <a class="dropdown-item" asp-controller="Professionals" asp-action="Edit" asp-route-id="@User.FindFirstValue("ProfessionalId")">Editar Informações</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Professionals" asp-action="Profile" asp-route-id="@User.FindFirstValue("ProfessionalId")">Ver Perfil Público</a>
                                        </li>
                                    </ul>
                                </li>
                            }

                            else if (User.IsInRole("Empresa"))
                            {
                                <li class="nav-item"><a class="nav-link ds-nav-link" asp-controller="Dashboard" asp-action="Index">Gestão da Empresa</a></li>
                            }

                            <li class="nav-item ms-lg-3 mt-3 mt-lg-0">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    <button type="submit" class="btn btn-link ds-nav-link text-decoration-none">Sair</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item mt-3 mt-lg-0">
                                <a class="nav-link ds-btn-ghost" asp-controller="Account" asp-action="Login">Entrar</a>
                            </li>
                            <li class="nav-item mt-2 mt-lg-0 ms-lg-2">
                                <a class="nav-link ds-btn-primary" asp-controller="Account" asp-action="Register">Criar Conta</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container" style="max-width: 1440px;">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-4 bg-white" style="border-color: var(--ds-border) !important;">
        <div class="container" style="max-width: 1440px;">
            <div class="d-flex justify-content-between align-items-center">
                <span>&copy; @DateTime.Now.Year - Agendify</span>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none ds-nav-link">Privacidade</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>