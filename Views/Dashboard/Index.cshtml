@model IEnumerable<SistemaAgendamentoWebII.Models.Appointment>
@using System.Security.Claims

@{
    ViewData["Title"] = "Meu Painel - Cliente";
    var userName = User.FindFirstValue(ClaimTypes.Name) ?? "Cliente";
}

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<div class="container py-3" style="max-width: 1200px;">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert d-flex align-items-center gap-3 mb-5 border-0 shadow-sm alert-dismissible fade show" role="alert"
             style="background-color: rgba(0, 163, 108, 0.1); color: #007a51; border-radius: 1rem;">
            <span class="material-symbols-outlined fs-3">task_alt</span>
            <div>
                <h4 class="h6 fw-bold mb-0">Tudo certo!</h4>
                <p class="mb-0 small">@TempData["SuccessMessage"]</p>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
        </div>
    }

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div class="d-flex align-items-center gap-3 mb-3">
            <!-- Círculo com a inicial -->
            <div class="text-white rounded-circle d-flex align-items-center justify-content-center fw-bold fs-4"
                 style="width: 56px; height: 56px; background-color: var(--ds-primary, #00236f); flex-shrink: 0;">
                @(!string.IsNullOrEmpty(userName) ? userName.Substring(0, 1).ToUpper() : "C")
            </div>

            <!-- Títulos -->
            <div>
                <h1 class="h3 fw-bold mb-1" style="color: var(--ds-primary, #00236f);">Olá, @userName!</h1>
                <p class="text-muted mb-0">Acompanhe os seus próximos agendamentos.</p>
            </div>
        </div>
        <a asp-controller="Home" asp-action="Explorar" class="btn text-white fw-bold px-4 py-2 d-inline-flex align-items-center gap-2" style="background: var(--ds-primary, #00236f); border-radius: 0.5rem;">
            <span class="material-symbols-outlined">add</span>
            Novo Agendamento
        </a>
    </div>
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">               
                <img src="~/img/bg.jpg" class="card-img" alt="Boas-vindas" style="max-height: 250px; object-fit: cover; border-radius: 0.9rem;">
            </div>
        </div>
    </div>

    <div class="card-header border-bottom-0 pt-4 pb-0 mb-3">
        <h4 class="fw-bold text-dark mb-0">Meus agendamentos</h4>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var appt in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge" style="background: rgba(0, 163, 108, 0.1); color: #007a51; padding: 6px 12px; border-radius: 2rem;">
                                    @appt.Status
                                </span>
                                <h3 class="h4 fw-bold mb-0 text-primary">
                                    @appt.AppointmentDate.ToString("dd/MM")
                                </h3>
                            </div>

                            <h4 class="h6 fw-bold mb-1">@(appt.Service?.Name ?? "Serviço não especificado")</h4>

                            <div class="d-flex align-items-center gap-2 text-muted small mt-3">
                                <span class="material-symbols-outlined" style="font-size: 16px;">schedule</span>
                                @appt.StartTime.ToString(@"hh\:mm")
                            </div>

                            <!-- INÍCIO DA CAIXA DE AVALIAÇÃO -->
                            @if (appt.Status == "Concluído" && appt.Rating == null)
                            {
                                <div class="mt-4 pt-3 border-top">
                                    <form asp-controller="Dashboard" asp-action="AvaliarProfissional" method="post" class="d-flex align-items-center justify-content-between gap-2">
                                        <input type="hidden" name="appointmentId" value="@appt.Id" />
                                        <select name="nota" class="form-select form-select-sm text-warning fw-bold bg-light border-0 shadow-sm w-auto" required>
                                            <option value="">Dar Nota...</option>
                                            <option value="5">⭐⭐⭐⭐⭐</option>
                                            <option value="4">⭐⭐⭐⭐</option>
                                            <option value="3">⭐⭐⭐</option>
                                            <option value="2">⭐⭐</option>
                                            <option value="1">⭐</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm text-white fw-bold px-3" style="background: var(--ds-primary, #00236f); border-radius: 0.4rem;">
                                            Avaliar
                                        </button>
                                    </form>
                                </div>
                            }
                            else if (appt.Status == "Concluído" && appt.Rating != null)
                            {
                                <div class="mt-4 pt-3 border-top text-center bg-light rounded-bottom p-2">
                                    <span class="small fw-bold text-muted me-2">Sua nota:</span>
                                    <span class="text-warning fs-6">
                                        @for (int i = 0; i < appt.Rating; i++)
                                        {
                                            <text>⭐</text>
                                        }
                                    </span>
                                </div>
                            }
                            <!-- FIM DA CAIXA DE AVALIAÇÃO -->

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            
            <div class="col-12 text-center py-5 mt-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3" style="width: 80px; height: 80px;">
                    <span class="material-symbols-outlined text-muted" style="font-size: 2.5rem;">event_busy</span>
                </div>
                <h4 class="fw-bold text-dark">Nenhum agendamento encontrado</h4>
                <p class="text-muted max-w-md mx-auto">Você ainda não possui horários marcados.</p>
            </div>
        }
    </div>
</div>