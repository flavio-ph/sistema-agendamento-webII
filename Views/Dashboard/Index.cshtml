@model IEnumerable<SistemaAgendamentoWebII.Models.Appointment>
@using System.Security.Claims

@{
    ViewData["Title"] = "Meu Painel - Cliente";
    // Extraímos o nome do utilizador diretamente do token de login
    var userName = User.FindFirstValue(ClaimTypes.Name) ?? "Cliente";
}

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<div class="container py-5" style="max-width: 1200px;">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
        <div>
            <h1 class="h3 fw-bold mb-1" style="color: var(--ds-text-main, #0b1c30);">Olá, @userName!</h1>
            <p class="text-muted mb-0">Acompanhe os seus próximos agendamentos.</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn text-white fw-bold px-4 py-2 d-inline-flex align-items-center gap-2" style="background: var(--ds-primary, #00236f); border-radius: 0.5rem;">
            <span class="material-symbols-outlined">add</span>
            Novo Agendamento
        </a>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var appt in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge" style="background: rgba(0, 163, 108, 0.1); color: #007a51; padding: 6px 12px; border-radius: 2rem;">
                                    Confirmado
                                </span>
                                <h3 class="h4 fw-bold mb-0 text-primary">@appt.AppointmentDate.ToString("dd/MM")</h3>
                            </div>

                            <h4 class="h6 fw-bold mb-1">@(appt.Service?.Name ?? "Serviço não especificado")</h4>

                            <div class="d-flex align-items-center gap-2 text-muted small mt-3">
                                <span class="material-symbols-outlined" style="font-size: 16px;">schedule</span>
                                @appt.AppointmentDate.ToString("HH:mm")
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 mt-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3" style="width: 80px; height: 80px;">
                    <span class="material-symbols-outlined text-muted" style="font-size: 2.5rem;">event_busy</span>
                </div>
                <h4 class="fw-bold text-dark">Nenhum agendamento encontrado</h4>
                <p class="text-muted max-w-md mx-auto">Você ainda não possui horários marcados. Explore os profissionais disponíveis e agende o seu primeiro serviço.</p>
            </div>
        }
    </div>
</div>