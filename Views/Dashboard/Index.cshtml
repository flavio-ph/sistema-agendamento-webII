@{
    Layout = null;
    var userName = User.Identity?.Name ?? "Usuário";
    var userRole = ViewBag.Role ?? "Cliente";
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agendify - Painel Administrativo</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .glass-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(197, 197, 211, 0.3);
        box-shadow: 0 4px 6px -1px rgba(30, 58, 138, 0.05);
        }

        .metric-gradient {
        background: linear-gradient(135deg, rgba(30, 58, 138, 0.05) 0%, rgba(30, 58, 138, 0) 100%);
        }
    </style>
</head>
<body class="bg-background text-on-surface min-h-screen flex font-body-md text-body-md overflow-x-hidden">

    <!-- Sidebar -->
    <nav class="h-screen w-72 fixed left-0 top-0 z-40 border-r border-outline-variant/20 shadow-xl shadow-primary/5 p-6 bg-surface hidden md:flex flex-col">
        <div class="mb-8 flex items-center gap-3 px-2 pt-2">
            <div class="h-10 w-10 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container font-headline-md text-headline-md uppercase">
                @userName.Substring(0, 1)
            </div>
            <div>
                <h2 class="font-bold text-primary text-lg leading-tight truncate">@userName</h2>
                <p class="text-xs text-on-surface-variant truncate">@userRole</p>
            </div>
        </div>
        <div class="flex-1 flex flex-col gap-2">
            <a class="bg-primary-container text-on-primary-container rounded-lg font-bold flex items-center gap-3 px-4 py-3 shadow-sm" href="#"><span class="material-symbols-outlined">dashboard</span> Dashboard</a>
            <a class="text-on-surface-variant hover:bg-surface-container-high rounded-lg flex items-center gap-3 px-4 py-3" href="#"><span class="material-symbols-outlined">calendar_today</span> Agendamentos</a>
        </div>
        <form asp-controller="Account" asp-action="Logout" method="post" class="mt-auto border-t pt-4">
            <button type="submit" class="w-full text-[#93000a] flex items-center gap-3 px-4 py-3 hover:bg-[#ffdad6]/30 rounded-lg"><span class="material-symbols-outlined">logout</span> Sair</button>
        </form>
    </nav>

    <main class="flex-1 md:ml-72 flex flex-col min-h-screen">
        <header class="md:hidden bg-surface/80 backdrop-blur-xl border-b border-outline-variant/30 sticky top-0 z-30 px-6 py-4 flex justify-between items-center">
            <h1 class="text-xl font-bold text-primary">Agendify Admin</h1>
        </header>

        <div class="p-6 md:p-10 max-w-[1440px] w-full mx-auto flex flex-col gap-8">

            @if (userRole == "Cliente")
            {
                <!-- ONBOARDING: Se for cliente comum, oferece upgrade -->
                <div class="glass-card rounded-2xl p-10 text-center border-t-4 border-primary">
                    <h1 class="text-3xl font-bold mb-4">Olá, @userName!</h1>
                    <p class="mb-8 text-on-surface-variant">Configure o seu perfil para começar a agendar ou oferecer serviços.</p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center">
                        <a asp-controller="Professionals" asp-action="Create" class="bg-primary text-white px-6 py-3 rounded-lg font-bold">Configurar Profissional</a>
                    </div>
                </div>
            }
            else
            {
                <!-- DASHBOARD COMPLETO: Visível para Profissionais/Admin -->
                <h1 class="text-3xl font-bold text-on-surface">Visão Geral da Plataforma</h1>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                    <div class="glass-card rounded-xl p-6 h-32 flex flex-col justify-between metric-gradient">
                        <span class="text-xs font-bold text-on-surface-variant uppercase">Novos Clientes</span>
                        <span class="text-3xl font-bold text-on-surface">@ViewBag.NovosClientes</span>
                    </div>
                    <!-- Outros cards aqui -->
                </div>
                <!-- Gestão de Parceiros -->
                <div class="glass-card rounded-xl overflow-hidden">
                    <!-- Tabela mantida fiel -->
                </div>
            }
        </div>
    </main>
</body>
</html>