@model SistemaAgendamentoWebII.Models.ViewModels.ProfessionalDashboardViewModel
@using SistemaAgendamentoWebII.Models
@using System.Security.Claims

@{
    ViewData["Title"] = "Painel do Profissional";
    var professional = Model?.Professional;
    var user = Model?.User;
}

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<style>
    /* Componentes Customizados do Painel conforme o Design System */
    .prof-card {
        background: var(--ds-surface, #ffffff);
        border: 1px solid var(--ds-border, #e5eeff);
        border-radius: 1rem; /* 16px */
        padding: 1.5rem;
        box-shadow: 0 12px 24px -8px rgba(30, 58, 138, 0.05);
    }

    .prof-stat-val {
        font-family: 'Manrope', sans-serif;
        font-weight: 700;
        color: var(--ds-text-main, #0b1c30);
    }

    /* Estilização das Soft Badges com 10% opacidade */
    .ds-badge-soft {
        padding: 6px 12px;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-block;
    }

    .badge-confirmado {
        background: rgba(0, 163, 108, 0.1);
        color: #007a51;
    }

    .badge-pendente {
        background: rgba(245, 158, 11, 0.1);
        color: #b45309;
    }

    .badge-cancelado {
        background: rgba(220, 38, 38, 0.1);
        color: #dc2626;
    }

    /* Gráfico de Barras SaaS Puro CSS (Fidelidade ao code.html) */
    .ds-chart-container {
        height: 200px;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        position: relative;
        padding-bottom: 1.5rem;
    }

    .ds-chart-grid-line {
        position: absolute;
        left: 0;
        right: 0;
        border-top: 1px dashed #e5eeff;
    }

    .ds-chart-bar-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-grow: 1;
        z-index: 2;
    }

    .ds-chart-bar {
        width: 32px;
        background-color: #d3e4fe; /* surface-container-highest */
        border-radius: 4px 4px 0 0;
        transition: all 0.3s ease;
        position: relative;
    }

        .ds-chart-bar.active {
            background: linear-gradient(180deg, #1e3a8a 0%, var(--ds-primary, #00236f) 100%);
            box-shadow: 0 0 12px rgba(0, 35, 111, 0.3);
        }

    .ds-chart-label {
        font-size: 0.75rem;
        color: var(--ds-text-muted, #444651);
        margin-top: 0.5rem;
        font-weight: 500;
    }

        .ds-chart-label.active {
            color: var(--ds-primary, #00236f);
            font-weight: 700;
        }
</style>

<div class="py-4">
    <div class="row align-items-center g-4 mb-5">
        <div class="col-md-8">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-primary-container text-white rounded-circle d-flex align-items-center justify-content-center fw-bold"
                     style="width: 56px; height: 56px; background-color: var(--ds-primary, #00236f);">
                    @((user?.Name?.Substring(0, 1) ?? "P").ToUpper())
                </div>
                <div>
                    <h1 class="h3 fw-bold mb-0" style="font-family: 'Manrope', sans-serif; color: var(--ds-primary, #00236f);">
                        Olá, @(Model?.User?.Name ?? User.Identity.Name)
                    </h1>
                    <p class="text-muted mb-0">
                        @(Model?.Professional?.Specialty ?? "Especialidade não definida") • Painel de Controle
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4 text-md-end">
            <a asp-controller="Appointments" asp-action="ProfessionalAgenda" class="btn btn-primary text-white bg-blue-900 fw-bold px-4 py-2 rounded-lg ...">
                <span class="material-symbols-outlined align-middle me-2">calendar_month</span>
                Ver Minha Agenda completa
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6 col-xl-3">
            <div class="prof-card h-100 d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="text-muted fw-semibold" style="font-size: 0.875rem;">Agendamentos Hoje</span>
                    <span class="material-symbols-outlined text-primary">today</span>
                </div>
                <div>
                    <h2 class="prof-stat-val h2 mb-0">@(Model?.AppointmentsTodayCount ?? 0)</h2>
                    <span class="text-success fw-medium" style="font-size: 0.75rem;">Pronto para o dia</span>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="prof-card h-100 d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="text-muted fw-semibold" style="font-size: 0.875rem;">Aguardando Confirmação</span>
                    <span class="material-symbols-outlined text-warning">pending_actions</span>
                </div>
                <div>
                    <h2 class="prof-stat-val h2 mb-0">@(Model?.PendingAppointmentsCount ?? 0)</h2>
                    <!-- Erro das aspas corrigido na linha abaixo: -->
                    <span class="text-muted" style="font-size: 0.75rem;">Requerem atenção</span>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="prof-card h-100 d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="text-muted fw-semibold" style="font-size: 0.875rem;">Ganhos Estimados (Mês)</span>
                    <span class="material-symbols-outlined text-secondary" style="color: var(--ds-secondary)!important;">payments</span>
                </div>
                <div>
                    <h2 class="prof-stat-val h2 mb-0">@((Model?.MonthlyEarnings ?? 0).ToString("C"))</h2>
                    <span class="text-success fw-medium" style="font-size: 0.75rem;">Faturação em progresso</span>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="prof-card h-100 d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="text-muted fw-semibold" style="font-size: 0.875rem;">Sua Avaliação</span>
                    <span class="material-symbols-outlined text-warning" style="font-variation-settings: 'FILL' 1;">star</span>
                </div>
                <div>
                    <h2 class="prof-stat-val h2 mb-0">@((Model?.AverageRating ?? 0).ToString("F1")) <span class="fs-6 text-muted">/ 5.0</span></h2>
                    <span class="text-muted" style="font-size: 0.75rem;">Média com base nos clientes</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <h3 class="h5 fw-bold mb-3" style="font-family: 'Manrope', sans-serif;">Frequência Semanal</h3>
            <div class="prof-card">
                <p class="text-muted mb-4" style="font-size: 0.875rem;">Distribuição de volume de agendamentos por dia da semana.</p>

                <div class="ds-chart-container">
                    <div class="ds-chart-grid-line" style="top: 25%;"></div>
                    <div class="ds-chart-grid-line" style="top: 50%;"></div>
                    <div class="ds-chart-grid-line" style="top: 75%;"></div>

                    @if (Model?.WeeklyOverview != null && Model.WeeklyOverview.Any())
                    {
                        foreach (var day in Model.WeeklyOverview)
                        {
                            <div class="ds-chart-bar-wrapper">
                                <div class="ds-chart-bar @(day.IsToday ? "active" : "")"
                                     style="height: @(day.PercentageValue)%;"
                                     title="@day.Count agendamentos">
                                </div>
                                <span class="ds-chart-label @(day.IsToday ? "active" : "")">@day.DayName</span>
                            </div>
                        }
                    }
                    else
                    {
                        var mockDays = new[] {
                            new { Name = "Seg", Val = 40, Act = false },
                            new { Name = "Ter", Val = 65, Act = false },
                            new { Name = "Qua", Val = 85, Act = true },
                            new { Name = "Qui", Val = 50, Act = false },
                            new { Name = "Sex", Val = 95, Act = false }
                        };
                        foreach (var m in mockDays)
                        {
                            <div class="ds-chart-bar-wrapper">
                                <div class="ds-chart-bar @(m.Act ? "active" : "")" style="height: @(m.Val)%;"></div>
                                <span class="ds-chart-label @(m.Act ? "active" : "")">@m.Name</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <h3 class="h5 fw-bold mb-3" style="font-family: 'Manrope', sans-serif;">Próximos Atendimentos</h3>
            <div class="ds-table-container">
                <table class="table ds-table mb-0">
                    <thead>
                        <tr>
                            <th>Cliente</th>
                            <th>Serviço Solicitado</th>
                            <th>Horário de Início</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.ProximosAtendimentos != null && ((IEnumerable<SistemaAgendamentoWebII.Models.Appointment>)ViewBag.ProximosAtendimentos).Any())
                        {
                            foreach (var item in ViewBag.ProximosAtendimentos)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-dark">@(item.Client?.Name ?? "Cliente Removido")</div>
                                        <div class="small text-muted">@(item.Client?.Email ?? "-")</div>
                                    </td>
                                    <td>
                                        <span class="fw-medium">@(item.Service?.Name ?? "-")</span>
                                    </td>
                                    <td class="text-primary fw-semibold">
                                        @item.StartTime.ToString(@"hh\:mm")
                                        <span class="text-muted small ms-1">(@item.AppointmentDate.ToString("dd/MM"))</span>
                                    </td>
                                    <td>
                                        <span class="badge py-1 px-3 rounded-pill @(item.Status == "Confirmado" ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning")">
                                            @item.Status
                                        </span>
                                    </td>                           
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">
                                    Nenhum atendimento programado para os próximos dias.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>