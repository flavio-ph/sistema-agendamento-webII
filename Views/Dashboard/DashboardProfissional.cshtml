@model SistemaAgendamentoWebII.Models.Professional
@using System.Security.Claims
@{
    Layout = null;
    if (Model == null)
    {
        <h1>Erro: Perfil de profissional não encontrado.</h1>
        return; // Interrompe a renderização da página
    }
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <title>Painel do Profissional - Agendify</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <style>
        .glass-panel {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(197, 197, 211, 0.3);
        }

        .soft-shadow {
        box-shadow: 0 10px 40px -10px rgba(30, 58, 138, 0.05);
        }
    </style>
</head>
<body class="bg-[#f8f9ff] text-[#0b1c30] font-['Inter'] flex">

    <!-- Sidebar -->
    <nav class="w-72 h-screen fixed bg-white border-r border-gray-200 p-6 flex flex-col">
        <h1 class="text-2xl font-extrabold text-[#00236f] mb-8">Agendify</h1>

        <div class="flex items-center gap-3 mb-8">
            <div class="w-10 h-10 rounded-full bg-gray-200"></div>
            <div>
                <!-- DADOS DINÂMICOS AQUI -->
                <p class="font-semibold text-sm">@Model.User.Name</p>
                <p class="text-xs text-gray-500">@Model.Specialty</p>
            </div>
        </div>

        <button class="w-full bg-[#00236f] text-white py-3 rounded-lg font-bold mb-8 flex items-center justify-center gap-2">
            <span class="material-symbols-outlined">add_circle</span> New Appointment
        </button>

        <ul class="space-y-2 flex-1">
            <li>
                <a href="#" class="bg-[#1e3a8a] text-white p-3 rounded-lg flex items-center gap-3">
                    <span class="material-symbols-outlined">grid_view</span> Dashboard
                </a>
            </li>
            <li>
                <a href="#" class="text-gray-600 p-3 rounded-lg flex items-center gap-3">
                    <span class="material-symbols-outlined">event</span> Schedule
                </a>
            </li>
            <li>
                <a href="#" class="text-gray-600 p-3 rounded-lg flex items-center gap-3">
                    <span class="material-symbols-outlined">person_search</span> Clients
                </a>
            </li>
            <li>
                <a asp-controller="Dashboard" asp-action="Perfil" asp-route-id="@User.FindFirstValue(ClaimTypes.NameIdentifier)"
                   class="text-gray-600 p-3 rounded-lg flex items-center gap-3 hover:bg-gray-50">
                    <span class="material-symbols-outlined">person</span> Meu Perfil
                </a>
            </li>
        </ul>
    </nav>

    <!-- Content -->
    <main class="ml-72 flex-1 p-10">
        <header class="mb-8">
            <h1 class="text-3xl font-bold">Visão Geral</h1>
            <p class="text-gray-500">Bem-vindo de volta, veja como está o seu dia.</p>
        </header>

        <!-- Métricas (Ainda estáticas, precisarão ser calculadas no Controller futuramente) -->
        <div class="grid grid-cols-3 gap-6 mb-8">
            <div class="glass-panel rounded-xl p-6 soft-shadow">
                <p class="text-sm text-gray-500">Receita do Mês</p>
                <h2 class="text-2xl font-bold">R$ 12.450</h2>
            </div>
            <div class="glass-panel rounded-xl p-6 soft-shadow">
                <p class="text-sm text-gray-500">Agendamentos</p>
                <h2 class="text-2xl font-bold">142</h2>
            </div>
            <div class="glass-panel rounded-xl p-6 soft-shadow">
                <p class="text-sm text-gray-500">Avaliação Média</p>
                <h2 class="text-2xl font-bold">4.9/5.0</h2>
            </div>
        </div>

        <div class="grid grid-cols-3 gap-6">
            <div class="col-span-2">
                <h3 class="text-lg font-bold mb-4">Agenda de Hoje</h3>
                <div class="space-y-4">
                    <!-- Agenda estática -->
                    <div class="glass-panel p-4 rounded-xl flex items-center justify-between">
                        <div>
                            <p class="font-bold">10:00 - Corte e Barba Premium</p>
                            <p class="text-sm text-gray-500">com Marcos Silva</p>
                        </div>
                        <div class="flex gap-2">
                            <button class="px-3 py-1 border rounded text-sm">Recusar</button>
                            <button class="px-3 py-1 bg-[#00236f] text-white rounded text-sm">Aceitar</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="glass-panel rounded-xl p-6">
                <h3 class="text-lg font-bold mb-4">Desempenho Semanal</h3>
                <div class="h-40 bg-gray-100 rounded-lg flex items-center justify-center text-gray-400">
                    [Gráfico Placeholder]
                </div>
            </div>
        </div>
    </main>
</body>
</html>