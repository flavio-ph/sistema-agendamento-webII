@model SistemaAgendamentoWebII.Models.Professional

@{
    var profissional = Model;
    var user = profissional?.User;

    // Fallback de segurança caso a role venha nula, mas a entidade central é o Profissional
    var userRole = user?.Role ?? "Profissional";

    var roleTheme = userRole switch
    {
        "Profissional" => new { Color = "var(--ds-primary)", Bg = "rgba(0, 35, 111, 0.1)", Icon = "badge" },
        "Empresa" => new { Color = "#059669", Bg = "rgba(5, 150, 105, 0.1)", Icon = "storefront" },
        _ => new { Color = "var(--ds-text-muted)", Bg = "rgba(68, 70, 81, 0.1)", Icon = "person" }
    };
}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<style>
    /* Design System Tokens Aprimorados */
    :root {
        --ds-bg: #f4f7fb;
        --ds-surface: #ffffff;
        --ds-primary: #00236f;
        --ds-secondary: #712edd;
        --ds-text-main: #0b1c30;
        --ds-text-muted: #64748b;
        --ds-border-light: #e2e8f0;
        --ds-radius-card: 1.25rem; /* 20px */
        --ds-shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        --ds-shadow-md: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
    }

    body {
        background-color: var(--ds-bg);
        font-family: 'Inter', sans-serif;
        color: var(--ds-text-muted);
    }

    h1, h2, h3, h4, h5 {
        font-family: 'Manrope', sans-serif;
        color: var(--ds-text-main);
        letter-spacing: -0.01em;
    }

    /* Cards e Containers */
    .ds-profile-card {
        background: var(--ds-surface);
        border: 1px solid var(--ds-border-light);
        border-radius: var(--ds-radius-card);
        box-shadow: var(--ds-shadow-sm);
        padding: 2rem;
        transition: all 0.3s ease;
    }

        .ds-profile-card:hover {
            box-shadow: var(--ds-shadow-md);
        }

    /* Avatares Dinâmicos */
    .ds-avatar-wrapper {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        padding: 6px;
        background: white;
        box-shadow: 0 0 0 1px var(--ds-border-light);
        margin: 0 auto;
    }

    .ds-avatar-inner {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        font-family: 'Manrope', sans-serif;
        font-weight: 700;
        color: white;
    }

    /* Botões */
    .ds-btn-primary {
        background: var(--ds-primary);
        color: white;
        border-radius: 0.75rem;
        padding: 0.6rem 1.5rem;
        font-weight: 600;
        transition: all 0.2s ease;
        border: none;
        text-decoration: none;
    }

        .ds-btn-primary:hover {
            background: #001a52;
            color: white;
            transform: translateY(-2px);
        }

    /* Badges */
    .ds-role-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        font-weight: 600;
        font-size: 0.875rem;
    }

    .ds-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
    }
</style>

<div class="container py-5" style="max-width: 1200px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 fw-bold">Perfil da Conta</h1>
        <a href="#" class="ds-btn-primary d-inline-flex align-items-center gap-2">
            <span class="material-symbols-outlined fs-5">edit</span> Editar Perfil
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="ds-profile-card text-center position-relative overflow-hidden h-100">
                <div class="position-absolute top-0 start-0 w-100" style="height: 60px; background: @(roleTheme.Bg); z-index: 0;"></div>

                <div class="position-relative z-1 mt-3">
                    <div class="ds-avatar-wrapper mb-3">
                        <div class="ds-avatar-inner" style="background: @(roleTheme.Color);">
                            @(user?.Name?.Substring(0, 1).ToUpper() ?? "U")
                        </div>
                    </div>

                    <h2 class="h4 fw-bold mb-1">@user?.Name</h2>
                    <p class="mb-3 text-muted">@user?.Email</p>

                    <div class="ds-role-badge mx-auto mb-4" style="background: @(roleTheme.Bg); color: @(roleTheme.Color);">
                        <span class="material-symbols-outlined fs-6">@(roleTheme.Icon)</span>
                        @userRole
                    </div>
                </div>

                <hr class="my-4" style="border-color: var(--ds-border-light);" />

                <div class="text-start">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="material-symbols-outlined text-muted fs-5">calendar_month</span>
                        <div>
                            <small class="d-block text-muted" style="font-size: 0.75rem;">Membro desde</small>
                            <span class="fw-medium text-dark">@(user?.CreatedAt.ToString("dd 'de' MMMM, yyyy") ?? "-")</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <span class="material-symbols-outlined text-success fs-5">check_circle</span>
                        <div>
                            <small class="d-block text-muted" style="font-size: 0.75rem;">Status da Conta</small>
                            <span class="fw-medium text-success">Ativa e Verificada</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="d-flex flex-column gap-4 h-100">

                <div class="ds-profile-card">
                    <h3 class="h5 fw-bold mb-4 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary">info</span>
                        Visão Geral
                    </h3>

                    @if (userRole == "Profissional" && profissional != null)
                    {
                        <div class="ds-info-grid mb-4">
                            <div class="p-3 rounded bg-light border">
                                <small class="text-muted d-block mb-1">Especialidade Principal</small>
                                <span class="fw-bold text-dark">@profissional.Specialty</span>
                            </div>
                            <div class="p-3 rounded bg-light border">
                                <small class="text-muted d-block mb-1">Tempo de Experiência</small>
                                <span class="fw-bold text-dark">@profissional.ExperienceYears anos</span>
                            </div>
                            <div class="p-3 rounded bg-light border">
                                <small class="text-muted d-block mb-1">Registro Profissional</small>
                                <span class="fw-bold text-dark">@(profissional.RegistrationNumber ?? "Não exigido")</span>
                            </div>
                        </div>

                        <h4 class="h6 fw-bold mb-2">Sobre Mim</h4>
                        <p class="mb-0" style="line-height: 1.6;">
                            @(string.IsNullOrWhiteSpace(profissional.Biography) ? "Nenhuma biografia fornecida." : profissional.Biography)
                        </p>
                    }
                    else if (userRole == "Empresa")
                    {
                        <div class="alert alert-success bg-opacity-10 border-0 d-flex align-items-start gap-3">
                            <span class="material-symbols-outlined text-success">business</span>
                            <div>
                                <h4 class="h6 fw-bold mb-1">Conta Empresarial</h4>
                                <p class="mb-0 text-muted" style="font-size: 0.875rem;">Sua conta tem permissões para gerenciar múltiplos profissionais e filiais. Acesse o painel de empresa para configurações avançadas.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary bg-light border-0 d-flex align-items-start gap-3">
                            <span class="material-symbols-outlined text-secondary">explore</span>
                            <div>
                                <h4 class="h6 fw-bold mb-1">Encontre Profissionais</h4>
                                <p class="mb-0 text-muted" style="font-size: 0.875rem;">Navegue pela plataforma e agende serviços com os melhores profissionais disponíveis na sua região.</p>
                            </div>
                        </div>
                    }
                </div>

                @if (userRole == "Profissional")
                {
                    <div class="ds-profile-card flex-grow-1">
                        <h3 class="h5 fw-bold mb-4 d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined text-warning">star</span>
                            Desempenho e Serviços
                        </h3>
                        <p class="text-muted">Espaço reservado para listar os serviços ativos, avaliações recentes ou integrações futuras do portfólio deste profissional.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>