@model SistemaAgendamentoWebII.Models.User
@{
    Layout = null;
}
<!DOCTYPE html>
<html class="light" lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Agendify - Cadastro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        [x-cloak] {
        display: none !important;
        }

        /* Scrollbar Customizada - Firefox */
        * {
        scrollbar-width: thin;
        scrollbar-color: #cbd5e1 transparent;
        }

        /* Scrollbar Customizada - Chrome, Edge, Safari */
        ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
        }

        ::-webkit-scrollbar-track {
        background: transparent;
        }

        ::-webkit-scrollbar-thumb {
        background-color: #cbd5e1; /* Tailwind slate-300 */
        border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
        background-color: #1e3a8a; /* Tailwind blue-900 (Design System Primary) */
        }
    </style>
</head>
<body class="bg-surface text-on-surface font-sans min-h-screen flex">

    <div class="hidden lg:flex lg:w-1/2 relative items-center justify-center bg-primary">
        <img src="https://i.postimg.cc/kX3y1jNm/bba3d743-6833-456b-b4f3-ab3261457fff.png" alt="Workspace" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-br from-blue-900/90 to-blue-800/85 mix-blend-multiply"></div>
        <div class="relative z-10 text-center text-white p-12">
            <h1 class="text-6xl font-bold mb-4">Agendify.</h1>
            <p class="text-xl text-blue-200">A sua plataforma de conexões locais.</p>
        </div>
    </div>

    <div class="w-full lg:w-1/2 flex items-center justify-center p-8 bg-gray-50 overflow-hidden">
        <div class="w-full max-w-[420px] max-h-screen overflow-y-auto p-4" x-data="{ role: 'Cliente' }">

            <div class="mb-8 pt-4">
                <h2 class="text-3xl font-bold text-gray-900 mb-2">Crie sua conta</h2>
                <p class="text-gray-600">Preencha os dados para começar.</p>
            </div>

            <form asp-action="Register" method="post" class="space-y-4 pb-12">
                @Html.AntiForgeryToken()

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Como deseja utilizar a plataforma?</label>
                    <select x-model="role" name="Role" class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600 bg-white">
                        <option value="Cliente">Cliente</option>
                        <option value="Profissional">Profissional</option>
                        <option value="Empresa">Empresa</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Nome Completo</label>
                    <input type="text" asp-for="Name" required
                           :pattern="role === 'Empresa' ? '.*' : '^[a-zA-ZÀ-ÿ]+\\s+[a-zA-ZÀ-ÿ]+.*$'"
                           title="Por favor, informe nome e sobrenome."
                           placeholder="Ex: João da Silva"
                           class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">E-mail</label>
                        <input type="email" asp-for="Email" required
                               placeholder="exemplo@email.com"
                               class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600" />
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Telefone</label>
                        <input type="tel" asp-for="Phone" maxlength="11"
                               placeholder="Ex: 79999999999"
                               class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600" />
                        <span asp-validation-for="Phone" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div x-show="role === 'Profissional'" x-cloak class="space-y-4 border-t pt-4 border-gray-200">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Especialidade Principal</label>
                        <input type="text" name="Specialty" :required="role === 'Profissional'"
                               maxlength="50"
                               onkeypress="return (event.charCode >= 65 && event.charCode <= 90) || (event.charCode >= 97 && event.charCode <= 122) || (event.charCode >= 192 && event.charCode <= 255) || event.charCode == 32"
                               title="Apenas letras são permitidas."
                               class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Anos de Experiência</label>
                            <input type="number" min="0" max="80" name="ExperienceYears"
                                   oninput="if(this.value > 80) this.value = 80; if(this.value < 0) this.value = 0;"
                                   class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Registo (CRM/CRO)</label>
                            <input type="text" name="RegistrationNumber" :required="role === 'Profissional'"
                                   maxlength="20"
                                   pattern="^[A-Za-z0-9/-]+$"
                                   title="Digite um formato válido (Apenas letras, números e traços. Ex: CRM-12345)"
                                   placeholder="Ex: CRM-12345"
                                   class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Descrição Curta</label>
                        <input type="text" name="Description"
                               onkeypress="return (event.charCode >= 65 && event.charCode <= 90) || (event.charCode >= 97 && event.charCode <= 122) || (event.charCode >= 192 && event.charCode <= 255) || event.charCode == 32"
                               title="Apenas letras são permitidas."
                               class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600"
                               placeholder="Ex: Especialista em reabilitação" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Biografia</label>
                        <textarea name="Biography" rows="3" class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600"></textarea>
                    </div>
                </div>

                <div x-show="role === 'Empresa'" x-cloak class="space-y-4 border-t pt-4 border-gray-200">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Nome do Estabelecimento</label>
                        <input type="text" name="EstablishmentName" :required="role === 'Empresa'" class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">CNPJ</label>
                        <input type="text" name="CNPJ" :required="role === 'Empresa'"
                               maxlength="14"
                               onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                               title="Digite apenas os 14 números do CNPJ"
                               placeholder="Ex: 00000000000000"
                               class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600" />
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4 border-t pt-4 border-gray-200 mt-2">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Senha</label>
                        <input type="password" asp-for="PasswordHash" required
                               placeholder="Mín. 6 (letras e números)"
                               class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600" />
                        <span asp-validation-for="PasswordHash" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Confirmar Senha</label>
                        <input type="password" asp-for="PasswordConfirmation" required
                               placeholder="Repita a senha idêntica"
                               class="w-full rounded-lg border-gray-300 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-600" />
                        <span asp-validation-for="PasswordConfirmation" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <button type="submit" class="w-full mt-6 py-3.5 bg-blue-900 text-white font-bold rounded-lg transition-transform hover:scale-[1.02]">
                    Concluir Registo
                </button>
            </form>
        </div>
    </div>
</body></html>