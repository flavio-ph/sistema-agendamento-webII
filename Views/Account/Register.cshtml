@model SistemaAgendamentoWebII.Models.User
@{
    Layout = null;
}
<!DOCTYPE html>
<html class="light" lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Agendify - Cadastro</title>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        [x-cloak] {
        display: none !important;
        }</style>
    </head>
    <body class="bg-surface text-on-surface font-sans min-h-screen flex">

        <div class="hidden lg:flex lg:w-1/2 relative items-center justify-center bg-primary overflow-hidden">
            <img src="https://i.postimg.cc/kX3y1jNm/bba3d743-6833-456b-b4f3-ab3261457fff.png" alt="Workspace" class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-br from-primary/90 to-primary-container/85 mix-blend-multiply"></div>
            <div class="relative z-10 text-center text-white p-12">
                <h1 class="text-6xl font-heading font-bold mb-4">Agendify.</h1>
                <p class="text-xl text-[#90a8ff]">A sua plataforma de conexões locais.</p>
            </div>
        </div>

        <div class="w-full lg:w-1/2 flex items-center justify-center p-8 bg-surface-container-lowest overflow-y-auto">
            <div class="w-full max-w-[420px]" x-data="{ role: 'Cliente' }">
                <div class="mb-8">
                    <h2 class="text-3xl font-heading font-bold text-on-surface mb-2">Crie sua conta</h2>
                    <p class="text-on-surface-variant">Preencha os dados para começar.</p>
                </div>

                <form asp-action="Register" method="post" class="space-y-4">
                    @Html.AntiForgeryToken()

                    <!-- 1. Perfil (Usando 'name' e 'id' simples para evitar erro CS1963) -->
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Como deseja utilizar a plataforma?</label>
                        <select x-model="role" name="Role" id="Role" class="w-full rounded-[8px] border-outline-variant bg-surface-container-lowest px-4 py-3 text-on-surface focus:border-primary outline-none">
                            <option value="Cliente">Cliente</option>
                            <option value="Profissional">Profissional</option>
                            <option value="Empresa">Empresa</option>
                        </select>
                    </div>

                    <!-- 2. Campos Obrigatórios (asp-for OK) -->
                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Nome Completo</label>
                        <input type="text" asp-for="Name" required class="w-full rounded-[8px] border-outline-variant bg-surface-container-lowest px-4 py-3 text-on-surface focus:border-primary outline-none" />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">E-mail</label>
                        <input type="email" asp-for="Email" required class="w-full rounded-[8px] border-outline-variant bg-surface-container-lowest px-4 py-3 text-on-surface focus:border-primary outline-none" />
                    </div>

                    <!-- 3. Campos Condicionais (Usando 'name' simples) -->
                    <div x-show="role === 'Profissional'" x-cloak>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Especialidade</label>
                        <input type="text" name="Specialty" class="w-full rounded-[8px] border-outline-variant bg-surface-container-lowest px-4 py-3 text-on-surface focus:border-primary outline-none" />
                    </div>

                    <div x-show="role === 'Empresa'" x-cloak>
                        <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Nome da Empresa</label>
                        <input type="text" name="EstablishmentName" class="w-full rounded-[8px] border-outline-variant bg-surface-container-lowest px-4 py-3 text-on-surface focus:border-primary outline-none" />
                    </div>

                    <!-- 4. Senhas -->
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Senha</label>
                            <input type="password" asp-for="PasswordHash" required class="w-full rounded-[8px] border-outline-variant bg-surface-container-lowest px-4 py-3 text-on-surface outline-none" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Confirmar</label>
                            <input type="password" name="PasswordConfirmation" required class="w-full rounded-[8px] border-outline-variant bg-surface-container-lowest px-4 py-3 text-on-surface outline-none" />
                        </div>
                    </div>

                    <button type="submit" class="w-full mt-6 py-3.5 bg-gradient-to-b from-[#1e3a8a] to-[#00236f] text-on-primary font-bold rounded-[8px] transition-all hover:scale-[1.02]">
                        Criar Conta
                    </button>
                </form>
            </div>
        </div>
    </body>
</html>