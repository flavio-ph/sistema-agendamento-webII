@model SistemaAgendamentoWebII.Models.User
@{
    Layout = null;
}
<!DOCTYPE html>
<html class="light" lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Agendify - Cadastro</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        :root {
        --ds-bg: #f8f9ff;
        --ds-surface: #ffffff;
        --ds-primary: #00236f;
        --ds-primary-hover: #1e3a8a;
        --ds-text-main: #0b1c30;
        --ds-text-muted: #444651;
        --ds-border: #e5eeff;
        --ds-ring: rgba(0, 35, 111, 0.15);
        }

        [x-cloak] { display: none !important; }

        * {
        scrollbar-width: thin;
        scrollbar-color: #cbd5e1 transparent;
        }

        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb {
        background-color: #cbd5e1;
        border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover { background-color: var(--ds-primary); }

        /* Padronização de Componentes UI */
        .ds-label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--ds-text-main);
        margin-bottom: 0.375rem;
        }

        .ds-input {
        width: 100%;
        border-radius: 0.5rem;
        border: 1px solid var(--ds-border);
        background-color: var(--ds-surface);
        padding: 0.75rem 1rem;
        outline: none;
        transition: all 0.2s ease-in-out;
        color: var(--ds-text-main);
        }

        .ds-input:focus {
        border-color: var(--ds-primary);
        box-shadow: 0 0 0 3px var(--ds-ring);
        }

        .ds-btn-primary {
        background: linear-gradient(180deg, var(--ds-primary-hover) 0%, var(--ds-primary) 100%);
        color: #ffffff;
        font-weight: 600;
        border-radius: 0.5rem;
        padding: 0.875rem;
        width: 100%;
        transition: transform 0.2s, box-shadow 0.2s;
        border: none;
        cursor: pointer;
        }

        .ds-btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px var(--ds-ring);
        }
    </style>
</head>
<body class="font-sans min-h-screen flex m-0 p-0" style="background-color: var(--ds-bg);">

    <!-- Painel Esquerdo: Marketing -->
    <div class="hidden lg:flex lg:w-1/2 relative items-center justify-center" style="background-color: var(--ds-primary);">
        <img src="https://i.postimg.cc/kX3y1jNm/bba3d743-6833-456b-b4f3-ab3261457fff.png" alt="Workspace" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 mix-blend-multiply" style="background: linear-gradient(to bottom right, rgba(30, 58, 138, 0.9), rgba(30, 58, 138, 0.85));"></div>
        <div class="relative z-10 text-center text-white p-12">
            <h1 class="text-6xl font-bold mb-4" style="font-family: 'Manrope', sans-serif; letter-spacing: -0.02em;">Agendify.</h1>
            <p class="text-xl" style="color: #bfdbfe;">A sua plataforma de conexões locais.</p>
        </div>
    </div>

    <!-- Painel Direito: Formulário com scroll independente -->
    <div class="w-full lg:w-1/2 h-screen overflow-y-auto flex items-center justify-center p-6 sm:p-12">
        <!-- O margin-y auto garante centralização vertical em telas grandes, o py-8 garante margem durante o scroll -->
        <div class="w-full max-w-md my-auto py-8" x-data="{ role: 'Cliente' }">

            <div class="mb-8">
                <h2 class="text-3xl font-bold mb-2" style="color: var(--ds-text-main); font-family: 'Manrope', sans-serif;">Crie sua conta</h2>
                <p style="color: var(--ds-text-muted);">Preencha os dados para começar.</p>
            </div>

            <form asp-action="Register" method="post" class="space-y-5">
                @Html.AntiForgeryToken()

                <div>
                    <label class="ds-label">Como deseja utilizar a plataforma?</label>
                    <select x-model="role" name="Role" class="ds-input">
                        <option value="Cliente">Cliente</option>
                        <option value="Profissional">Profissional</option>
                        <option value="Empresa">Empresa</option>
                    </select>
                </div>

                <div>
                    <label class="ds-label">Nome Completo</label>
                    <input type="text" asp-for="Name" required
                           :pattern="role === 'Empresa' ? '.*' : '^[a-zA-ZÀ-ÿ]+\\s+[a-zA-ZÀ-ÿ]+.*$'"
                           title="Por favor, informe nome e sobrenome."
                           placeholder="Ex: João da Silva"
                           class="ds-input" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="ds-label">E-mail</label>
                        <input type="email" asp-for="Email" required placeholder="exemplo@email.com" class="ds-input" />
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label class="ds-label">Telefone</label>
                        <input type="tel" asp-for="Phone" maxlength="11" placeholder="Ex: 79999999999" class="ds-input" />
                        <span asp-validation-for="Phone" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <!-- Secção Condicional: Profissional -->
                <div x-show="role === 'Profissional'" x-cloak class="space-y-5 pt-4 mt-2 border-t" style="border-color: var(--ds-border);">
                    <div>
                        <label class="ds-label">Especialidade Principal</label>
                        <input type="text" name="Specialty" :required="role === 'Profissional'"
                               maxlength="50"
                               onkeypress="return (event.charCode >= 65 && event.charCode <= 90) || (event.charCode >= 97 && event.charCode <= 122) || (event.charCode >= 192 && event.charCode <= 255) || event.charCode == 32"
                               title="Apenas letras são permitidas."
                               class="ds-input" placeholder="Ex: Fisioterapeuta" />
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="ds-label">Anos de Experiência</label>
                            <input type="number" min="0" max="80" name="ExperienceYears"
                                   oninput="if(this.value > 80) this.value = 80; if(this.value < 0) this.value = 0;"
                                   class="ds-input" placeholder="Ex: 5" />
                        </div>
                        <div>
                            <label class="ds-label">Registo (CRM/CRO)</label>
                            <input type="text" name="RegistrationNumber" :required="role === 'Profissional'"
                                   maxlength="20"
                                   pattern="^[A-Za-z0-9/-]+$"
                                   title="Apenas letras, números e traços."
                                   placeholder="Ex: CRM-12345"
                                   class="ds-input" />
                        </div>
                    </div>
                    <div>
                        <label class="ds-label">Descrição Curta</label>
                        <input type="text" name="Description"
                               onkeypress="return (event.charCode >= 65 && event.charCode <= 90) || (event.charCode >= 97 && event.charCode <= 122) || (event.charCode >= 192 && event.charCode <= 255) || event.charCode == 32"
                               class="ds-input" placeholder="Ex: Especialista em reabilitação" />
                    </div>
                    <div>
                        <label class="ds-label">Biografia</label>
                        <textarea name="Biography" rows="3" class="ds-input resize-none" placeholder="Breve resumo profissional"></textarea>
                    </div>
                </div>

                <!-- Secção Condicional: Empresa -->
                <div x-show="role === 'Empresa'" x-cloak class="space-y-5 pt-4 mt-2 border-t" style="border-color: var(--ds-border);">
                    <div>
                        <label class="ds-label">Nome do Estabelecimento</label>
                        <input type="text" name="EstablishmentName" :required="role === 'Empresa'" class="ds-input" placeholder="Razão social ou Nome fantasia" />
                    </div>
                    <div>
                        <label class="ds-label">CNPJ</label>
                        <input type="text" name="CNPJ" :required="role === 'Empresa'"
                               maxlength="14"
                               onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                               title="Digite apenas os 14 números do CNPJ"
                               placeholder="Ex: 00000000000000"
                               class="ds-input" />
                    </div>
                </div>

                <!-- Senhas -->
                <div class="space-y-4 pt-4 mt-2 border-t" style="border-color: var(--ds-border);">
                    <div>
                        <label class="ds-label">Senha</label>
                        <input type="password" asp-for="PasswordHash" required placeholder="Mín. 6 (letras e números)" class="ds-input" />
                        <span asp-validation-for="PasswordHash" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label class="ds-label">Confirmar Senha</label>
                        <input type="password" asp-for="PasswordConfirmation" required placeholder="Repita a senha idêntica" class="ds-input" />
                        <span asp-validation-for="PasswordConfirmation" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="pt-2">
                    <button type="submit" class="ds-btn-primary">
                        Concluir Registo
                    </button>
                </div>
            </form>

            <div class="mt-6 text-center">
                <p class="text-sm" style="color: var(--ds-text-muted);">
                    Já tem uma conta? <a asp-controller="Account" asp-action="Login" class="font-semibold transition-colors" style="color: var(--ds-primary);">Entrar</a>
                </p>
            </div>

        </div>
    </div>
</body>
</html>