@{
    ViewData["Title"] = "Recuperar Senha";
}

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<div class="container py-5 d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card border-0 shadow-sm p-4 p-md-5" style="border-radius: 1.25rem; max-width: 450px; width: 100%;">

        <div class="text-center mb-4">
            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <span class="material-symbols-outlined fs-1" style="color: var(--ds-primary, #00236f);">lock_reset</span>
            </div>
            <h1 class="h3 fw-bold text-dark mb-2">Esqueceu a senha?</h1>
            <p class="text-muted small px-3">
                Não se preocupe! Digite o seu e-mail abaixo e enviaremos as instruções para redefinir a sua senha.
            </p>
        </div>

        <form asp-controller="Account" asp-action="ForgotPassword" method="post">
            <div class="mb-4">
                <label for="email" class="form-label fw-bold text-muted small">E-mail Cadastrado</label>
                <input type="email" id="email" name="email" class="form-control form-control-lg bg-light" placeholder="exemplo@email.com" required />
                @Html.ValidationMessage("Email", new { @class = "text-danger small fw-bold mt-1" })
            </div>

            <button type="submit" class="btn w-100 text-white fw-bold py-3 mb-4" style="background: var(--ds-primary, #00236f); border-radius: 0.5rem; transition: transform 0.2s;">
                Enviar link de recuperação
            </button>

            <div class="text-center">
                <a asp-action="Login" class="text-decoration-none text-muted small fw-semibold transition-colors d-inline-flex align-items-center gap-1" style="color: var(--ds-primary, #00236f);">
                    <span class="material-symbols-outlined" style="font-size: 18px;">arrow_back</span>
                    Voltar para o Login
                </a>
            </div>
        </form>

    </div>
</div>
