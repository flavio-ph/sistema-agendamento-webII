@model SistemaAgendamentoWebII.Models.Professional
@using System.Security.Claims

@{
    ViewData["Title"] = Model.User?.Name ?? "Perfil do Profissional";

    // Identifica se o perfil acessado é o do próprio usuário logado
    var usuarioLogadoId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var ehOProprioPerfil = usuarioLogadoId == Model.UserId.ToString();
}

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<div class="container py-5" style="max-width: 1000px;">

    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted d-inline-flex align-items-center gap-2 mb-4">
        <span class="material-symbols-outlined fs-5">arrow_back</span>
        Voltar para a lista
    </a>

    <div class="card border-0 shadow-sm mb-5" style="border-radius: 1.25rem; overflow: hidden;">
        <div class="card-body p-4 p-md-5">
            <div class="row align-items-center text-center text-md-start g-4">
                <div class="col-md-auto">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center fw-bold mx-auto"
                         style="width: 120px; height: 120px; font-size: 3rem; color: var(--ds-primary, #00236f); border: 2px solid var(--ds-border-light, #e2e8f0);">
                        @(Model.User?.Name?.Substring(0, 1).ToUpper() ?? "P")
                    </div>
                </div>
                <div class="col-md">
                    <h1 class="h3 fw-bold mb-1 text-dark">@Model.User?.Name</h1>
                    <p class="text-muted fs-5 mb-3">@(Model.Specialty ?? "Profissional Independente")</p>

                    <div class="d-flex flex-wrap justify-content-center justify-content-md-start gap-3 mb-3">
                        <span class="badge bg-light text-dark border py-2 px-3">
                            <span class="text-warning">⭐</span> @Model.AverageRating.ToString("0.0")
                        </span>
                        <span class="badge bg-light text-dark border py-2 px-3">
                            <span class="material-symbols-outlined fs-6 align-text-bottom">work_history</span>
                            @(Model.ExperienceYears ?? 0) anos exp.
                        </span>
                    </div>
                </div>
            </div>

            <hr class="my-4 text-muted" />

            <h2 class="h5 fw-bold mb-3">Sobre Mim</h2>
            <p class="text-muted" style="line-height: 1.7;">
                @(string.IsNullOrWhiteSpace(Model.Biography) ? "Este profissional ainda não adicionou uma biografia." : Model.Biography)
            </p>
        </div>
    </div>

    <h2 class="h4 fw-bold mb-4">Serviços e Agendamentos</h2>

    <div class="row g-4">
        @if (Model.Services != null && Model.Services.Any())
        {
            foreach (var servico in Model.Services)
            {
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" style="border-radius: 1rem;">
                        <div class="card-body p-4 d-flex flex-column">
                            <h3 class="h5 fw-bold mb-2">@servico.Name</h3>
                            <p class="text-muted small mb-4 flex-grow-1">@servico.Description</p>

                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <div>
                                    <span class="d-block fw-bold fs-5 text-dark">R$ @servico.Price.ToString("F2")</span>
                                    <span class="text-muted small">⏱ @servico.DurationMinutes min</span>
                                </div>

                                @if (!ehOProprioPerfil)
                                {
                                    <a asp-controller="Appointments" asp-action="Create" asp-route-serviceId="@servico.Id"
                                       class="btn text-white fw-bold px-4" style="background: var(--ds-primary, #00236f); border-radius: 0.5rem;">
                                        Agendar
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-secondary fw-bold px-4" style="border-radius: 0.5rem;" disabled title="Este é o seu próprio serviço">
                                        Seu Serviço
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-secondary bg-light border-0 text-center py-5" style="border-radius: 1rem;">
                    <span class="material-symbols-outlined fs-1 text-muted mb-3">inventory_2</span>
                    <h4 class="h5 fw-bold text-dark">Nenhum serviço cadastrado</h4>
                    <p class="text-muted mb-0">Este profissional ainda não configurou a sua lista de serviços.</p>
                </div>
            </div>
        }
    </div>
</div>