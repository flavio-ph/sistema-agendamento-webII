@model IEnumerable<SistemaAgendamentoWebII.Models.Professional>

@{
    ViewData["Title"] = "Gerir Equipe";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark" style="font-family: 'Manrope', sans-serif;">Gestão da Equipe</h2>
            <p class="text-muted mb-0">Gerencie os profissionais vinculados ao seu estabelecimento.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Dashboard" asp-action="DashboardEmpresa" class="btn btn-outline-secondary">
                Voltar ao Painel
            </a>
          
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4 py-3 border-bottom-0 text-muted" style="font-weight: 600; font-size: 0.85rem;">Nome</th>
                        <th class="py-3 border-bottom-0 text-muted" style="font-weight: 600; font-size: 0.85rem;">E-mail</th>
                        <th class="py-3 border-bottom-0 text-muted text-end px-4" style="font-weight: 600; font-size: 0.85rem;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var prof in Model)
                        {
                            <tr>
                                <td class="px-4 py-3">
                                    <div class="fw-semibold text-dark">@(prof.User?.Name ?? "Profissional")</div>
                                </td>
                                <td class="py-3 text-muted">
                                    @(prof.User?.Email ?? "-")
                                </td>
                                <td class="py-3 text-end px-4">
                                    <form asp-controller="Professionals" asp-action="RemoverVinculo" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="professionalId" value="@prof.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm rounded-2 fw-medium"
                                                onclick="return confirm('Tem certeza? Isso removerá o profissional da sua equipe e APAGARÁ todos os agendamentos dele!');">
                                            Remover da Equipe
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="px-4 py-5 text-center text-muted">
                                <span class="material-symbols-outlined fs-2 d-block mb-2">group_off</span>
                                Nenhum profissional na sua equipe no momento.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>