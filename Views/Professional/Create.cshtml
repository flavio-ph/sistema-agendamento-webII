@model SistemaAgendamentoWebII.Models.Professional
@{
    Layout = null;
    var userName = User.Identity?.Name ?? "Parceiro";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Torne-se um Profissional - Agendify</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        surface: '#f8f9ff', 'surface-container-lowest': '#ffffff', 'surface-container-low': '#eff4ff',
        'on-surface': '#0b1c30', 'on-surface-variant': '#444651', outline: '#757682', 'outline-variant': '#c5c5d3',
        primary: '#00236f', 'primary-container': '#1e3a8a', 'on-primary': '#ffffff'
        },
        fontFamily: { sans: ['Inter', 'sans-serif'], heading: ['Manrope', 'sans-serif'] }
        }
        }
        }
    </script>
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .glass-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(197, 197, 211, 0.4);
        box-shadow: 0 10px 30px -10px rgba(30, 58, 138, 0.08);
        }
    </style>
</head>
<body class="bg-surface text-on-surface font-sans min-h-screen flex items-center justify-center p-6 antialiased relative overflow-hidden">

    <div class="absolute top-0 left-0 w-full h-96 bg-primary/5 rounded-full blur-3xl -z-10 pointer-events-none transform -translate-y-1/2"></div>

    <div class="glass-card w-full max-w-2xl rounded-[16px] p-8 sm:p-12 relative z-10 bg-surface-container-lowest">

        <div class="mb-8 text-center">
            <div class="w-16 h-16 bg-surface-container-low text-primary rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="material-symbols-outlined text-3xl">storefront</span>
            </div>
            <h2 class="text-3xl font-heading font-bold text-on-surface mb-2">Configure o seu Perfil</h2>
            <p class="text-on-surface-variant font-medium">Olá, @userName. Insira as informações da sua atuação profissional para ativar o seu calendário no Agendify.</p>
        </div>

        <form asp-controller="Professionals" asp-action="Create" method="post" class="space-y-6">
            @Html.AntiForgeryToken()

            <div>
                <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Especialidade Principal</label>
                <input type="text" asp-for="Specialty" required class="w-full rounded-[8px] border-outline-variant bg-surface px-4 py-3 text-on-surface transition-all focus:border-primary focus:ring-[4px] focus:ring-primary/20 outline-none" placeholder="Ex: Estética Avançada, Barbearia, Fisioterapia" />
            </div>

            <div>
                <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Anos de Experiência</label>
                <input type="number" asp-for="ExperienceYears" min="0" required class="w-full rounded-[8px] border-outline-variant bg-surface px-4 py-3 text-on-surface transition-all focus:border-primary focus:ring-[4px] focus:ring-primary/20 outline-none" placeholder="Ex: 5" />
            </div>

            <div>
                <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Biografia (Aparecerá no seu perfil público)</label>
                <textarea asp-for="Biography" rows="4" required class="w-full rounded-[8px] border-outline-variant bg-surface px-4 py-3 text-on-surface transition-all focus:border-primary focus:ring-[4px] focus:ring-primary/20 outline-none resize-none" placeholder="Conte um pouco sobre sua trajetória e foco de atendimento..."></textarea>
            </div>

            <div class="pt-4 border-t border-outline-variant/30 flex justify-end gap-3">
                <a asp-controller="Dashboard" asp-action="Index" class="px-6 py-3 font-semibold text-on-surface-variant hover:bg-surface-container-low rounded-lg transition-colors">
                    Cancelar
                </a>
                <button type="submit" class="px-8 py-3 bg-gradient-to-b from-primary-container to-primary hover:scale-[1.02] text-on-primary font-bold rounded-lg shadow-sm transition-transform flex items-center gap-2">
                    Ativar Perfil Profissional
                    <span class="material-symbols-outlined text-[20px]">check_circle</span>
                </button>
            </div>
        </form>

    </div>
</body>
</html>