@{
    Layout = null;
    // Variáveis temporárias para validação visual antes da injeção do Entity Framework
    var professionalName = "Marina Costa";
    var specialty = "Estética Avançada";
    var bio = "Especialista em cuidados faciais e corporais com mais de 8 anos de experiência. Focada em realçar a beleza natural através de procedimentos seguros e tecnologias de ponta.";
    var rating = "4.9";
    var reviewsCount = 128;
}
<!DOCTYPE html>
<html class="scroll-smooth" lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@professionalName - Agendify</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        colors: {
        surface: '#f8f9ff',
        'surface-container-lowest': '#ffffff',
        'surface-container-low': '#eff4ff',
        'surface-container': '#e5eeff',
        'on-surface': '#0b1c30',
        'on-surface-variant': '#444651',
        outline: '#757682',
        'outline-variant': '#c5c5d3',
        primary: '#00236f',
        'primary-container': '#1e3a8a',
        'on-primary': '#ffffff',
        secondary: '#712edd',
        'secondary-container': '#8b4ef7'
        },
        fontFamily: {
        sans: ['Inter', 'sans-serif'],
        heading: ['Manrope', 'sans-serif']
        }
        }
        }
        }
    </script>
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .glass-panel {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(197, 197, 211, 0.3);
        }

        .soft-shadow {
        box-shadow: 0 4px 20px -2px rgba(0, 35, 111, 0.05);
        }
    </style>
</head>
<body class="bg-surface text-on-surface font-sans antialiased min-h-screen flex flex-col">

    <nav class="bg-surface/90 backdrop-blur-md fixed top-0 w-full z-50 border-b border-outline-variant/30 transition-all">
        <div class="flex justify-between items-center w-full px-6 md:px-10 h-20 max-w-[1440px] mx-auto">
            <a href="/" class="font-heading text-2xl font-extrabold text-primary flex items-center gap-2 transition-transform hover:scale-[1.02]">
                <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">event_available</span>
                Agendify
            </a>
            <div class="flex items-center gap-4">
                <a asp-controller="Account" asp-action="Login" class="text-on-surface-variant hover:text-primary font-semibold transition-colors">Entrar</a>
            </div>
        </div>
    </nav>

    <main class="flex-1 max-w-[1200px] mx-auto w-full px-6 md:px-10 pt-32 pb-24">

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

            <aside class="lg:col-span-4 flex flex-col gap-6">
                <div class="glass-panel rounded-2xl p-8 soft-shadow flex flex-col items-center text-center relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-24 bg-gradient-to-br from-primary-container to-primary"></div>

                    <div class="w-32 h-32 rounded-full border-4 border-surface-container-lowest bg-surface-container shadow-md overflow-hidden relative z-10 mb-4">
                        <img src="https://images.unsplash.com/photo-1595152772835-219674b2a8a6?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="@professionalName" class="w-full h-full object-cover" />
                    </div>

                    <h1 class="font-heading text-2xl font-bold text-on-surface">@professionalName</h1>
                    <span class="mt-1 inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-surface-container-low text-primary border border-outline-variant/30">
                        @specialty
                    </span>

                    <div class="flex items-center gap-2 mt-4 text-on-surface-variant">
                        <span class="material-symbols-outlined text-[#eab308]" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="font-bold text-on-surface">@rating</span>
                        <span class="text-sm">(@reviewsCount avaliações)</span>
                    </div>

                    <div class="w-full h-px bg-outline-variant/30 my-6"></div>

                    <div class="w-full flex flex-col gap-3 text-left">
                        <div class="flex items-start gap-3 text-on-surface-variant">
                            <span class="material-symbols-outlined text-outline">location_on</span>
                            <span class="text-sm font-medium">Av. Paulista, 1000 - Bela Vista<br />São Paulo, SP</span>
                        </div>
                        <div class="flex items-center gap-3 text-on-surface-variant">
                            <span class="material-symbols-outlined text-outline">verified</span>
                            <span class="text-sm font-medium text-[#006e1c]">Profissional Verificado</span>
                        </div>
                    </div>
                </div>

                <div class="glass-panel rounded-2xl p-8 soft-shadow">
                    <h2 class="font-heading text-lg font-bold text-on-surface mb-3">Sobre o profissional</h2>
                    <p class="text-on-surface-variant text-sm leading-relaxed">
                        @bio
                    </p>
                </div>
            </aside>

            <div class="lg:col-span-8 flex flex-col gap-6">
                <div class="flex items-center justify-between border-b border-outline-variant/30 pb-4">
                    <h2 class="font-heading text-2xl font-bold text-on-surface">Serviços Oferecidos</h2>
                    <div class="relative w-48 hidden sm:block">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline-variant" style="font-size: 18px;">search</span>
                        <input class="w-full pl-9 pr-3 py-2 bg-surface border border-outline-variant/50 rounded-lg text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Buscar serviço..." type="text" />
                    </div>
                </div>

                <div class="flex flex-col gap-4">

                    <div class="glass-panel rounded-xl p-5 hover:border-primary/40 transition-colors group flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                        <div class="flex-1">
                            <h3 class="font-heading text-lg font-bold text-on-surface group-hover:text-primary transition-colors">Limpeza de Pele Profunda</h3>
                            <p class="text-sm text-on-surface-variant mt-1 line-clamp-2">Extração de cravos, peeling ultrassônico e máscara calmante. Ideal para renovação celular.</p>
                            <div class="flex items-center gap-4 mt-3">
                                <span class="flex items-center gap-1.5 text-xs font-semibold text-outline">
                                    <span class="material-symbols-outlined" style="font-size: 16px;">schedule</span> 60 min
                                </span>
                            </div>
                        </div>
                        <div class="flex sm:flex-col items-center sm:items-end justify-between sm:justify-center border-t sm:border-t-0 border-outline-variant/20 pt-4 sm:pt-0 sm:pl-4 sm:border-l min-w-[140px]">
                            <span class="font-heading text-xl font-extrabold text-on-surface">R$ 150</span>
                            <button class="mt-2 px-5 py-2.5 bg-gradient-to-b from-primary-container to-primary text-white font-bold rounded-lg shadow-sm hover:scale-[1.02] transition-transform flex items-center gap-2">
                                Reservar
                            </button>
                        </div>
                    </div>

                    <div class="glass-panel rounded-xl p-5 hover:border-primary/40 transition-colors group flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                        <div class="flex-1">
                            <h3 class="font-heading text-lg font-bold text-on-surface group-hover:text-primary transition-colors">Microagulhamento</h3>
                            <p class="text-sm text-on-surface-variant mt-1 line-clamp-2">Tratamento para cicatrizes de acne, manchas e rejuvenescimento facial com ativos estéreis.</p>
                            <div class="flex items-center gap-4 mt-3">
                                <span class="flex items-center gap-1.5 text-xs font-semibold text-outline">
                                    <span class="material-symbols-outlined" style="font-size: 16px;">schedule</span> 90 min
                                </span>
                            </div>
                        </div>
                        <div class="flex sm:flex-col items-center sm:items-end justify-between sm:justify-center border-t sm:border-t-0 border-outline-variant/20 pt-4 sm:pt-0 sm:pl-4 sm:border-l min-w-[140px]">
                            <span class="font-heading text-xl font-extrabold text-on-surface">R$ 280</span>
                            <button class="mt-2 px-5 py-2.5 border border-primary text-primary font-bold rounded-lg hover:bg-surface-container-low transition-colors flex items-center gap-2">
                                Reservar
                            </button>
                        </div>
                    </div>

                    <div class="glass-panel rounded-xl p-5 hover:border-primary/40 transition-colors group flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                        <div class="flex-1">
                            <h3 class="font-heading text-lg font-bold text-on-surface group-hover:text-primary transition-colors">Drenagem Linfática</h3>
                            <p class="text-sm text-on-surface-variant mt-1 line-clamp-2">Massagem corporal focada na redução de retenção de líquidos e melhora da circulação.</p>
                            <div class="flex items-center gap-4 mt-3">
                                <span class="flex items-center gap-1.5 text-xs font-semibold text-outline">
                                    <span class="material-symbols-outlined" style="font-size: 16px;">schedule</span> 50 min
                                </span>
                            </div>
                        </div>
                        <div class="flex sm:flex-col items-center sm:items-end justify-between sm:justify-center border-t sm:border-t-0 border-outline-variant/20 pt-4 sm:pt-0 sm:pl-4 sm:border-l min-w-[140px]">
                            <span class="font-heading text-xl font-extrabold text-on-surface">R$ 120</span>
                            <button class="mt-2 px-5 py-2.5 border border-primary text-primary font-bold rounded-lg hover:bg-surface-container-low transition-colors flex items-center gap-2">
                                Reservar
                            </button>a
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </main>

    <footer class="w-full py-8 border-t border-outline-variant/30 bg-surface-container-lowest mt-auto">
        <div class="max-w-[1200px] mx-auto px-6 md:px-10 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="font-heading text-lg font-extrabold text-primary flex items-center gap-2">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">event_available</span>
                Agendify
            </div>
            <div class="font-medium text-sm text-on-surface-variant">© 2026 Agendify Technologies. Todos os direitos reservados.</div>
        </div>
    </footer>

</body>
</html>