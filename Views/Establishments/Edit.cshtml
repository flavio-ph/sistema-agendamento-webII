@model SistemaAgendamentoWebII.Models.Establishment

@{
    ViewData["Title"] = "Editar Empresa";
}

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            
            <div class="card shadow-sm border-0" style="border-radius: 1.25rem;">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="d-flex align-items-center gap-3 mb-4 pb-2 border-bottom">
                        <span class="material-symbols-outlined fs-2" style="color: var(--ds-primary, #00236f);">storefront</span>
                        <div>
                            <h1 class="h4 fw-bold mb-0" style="font-family: 'Manrope', sans-serif; color: var(--ds-primary, #00236f);">
                                Editar Empresa
                            </h1>
                            <p class="text-muted small mb-0 mt-1">Atualize os dados do seu estabelecimento</p>
                        </div>
                    </div>

                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-4 fw-bold p-3 bg-danger bg-opacity-10 rounded border border-danger border-opacity-25" style="display: @(ViewData.ModelState.IsValid ? "none" : "block");"></div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-muted small">Nome do Estabelecimento <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control form-control-lg bg-light" placeholder="Ex: Barbearia do João" required />
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CNPJ" class="form-label fw-bold text-muted small">CNPJ <span class="text-danger">*</span></label>
                            <input asp-for="CNPJ" id="cnpjInput" class="form-control form-control-lg bg-light" maxlength="18" placeholder="00.000.000/0001-00" required />
                            <span asp-validation-for="CNPJ" class="text-danger small mt-1 d-block"></span>
                            <div class="form-text small">Digite apenas números. A formatação será aplicada automaticamente.</div>
                        </div>

                        <div class="d-flex flex-column flex-sm-row justify-content-end gap-3 mt-5 pt-3 border-top">
                            <a asp-controller="Dashboard" asp-action="DashboardEmpresa" class="btn btn-light fw-bold px-4 py-2 border rounded-3 text-center">Cancelar</a>
                            <button type="submit" class="btn text-white fw-bold px-4 py-2 rounded-3 text-center" style="background: linear-gradient(180deg, #1e3a8a 0%, var(--ds-primary, #00236f) 100%); box-shadow: 0 4px 12px rgba(0, 35, 111, 0.15);">
                                Salvar Alterações
                            </button>
                        </div>
                    </form>
                    
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    
    <script>
        $(document).ready(function () {
            // Aplica a formatação visual do CNPJ (00.000.000/0001-00)
            $('#cnpjInput').mask('00.000.000/0000-00', {reverse: true});
            
            // Dica: Se o seu backend espera receber o CNPJ SEM pontuação (apenas os 14 números),
            // você deve interceptar o formulário antes do submit e limpar os caracteres especiais:
            $('form').on('submit', function() {
                var cnpjField = $('#cnpjInput');
                cnpjField.val(cnpjField.val().replace(/[^\d]+/g, ''));
            });
        });
    </script>
}