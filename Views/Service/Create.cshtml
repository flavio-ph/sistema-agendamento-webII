@model SistemaAgendamentoWebII.Models.Service

@{
    ViewData["Title"] = "Novo Serviço";
}

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<div class="container py-5" style="max-width: 800px;">
    <div class="card shadow-sm border-0" style="border-radius: 1.25rem;">
        <div class="card-body p-4 p-md-5">
            <div class="d-flex align-items-center gap-3 mb-4">
                <span class="material-symbols-outlined fs-2" style="color: var(--ds-primary, #00236f);">add_circle</span>
                <h1 class="h3 fw-bold mb-0" style="font-family: 'Manrope', sans-serif;">Cadastrar Novo Serviço</h1>
            </div>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="text-danger small mb-3 fw-bold p-2 bg-danger bg-opacity-10 rounded"></div>
                <div class="row g-4 mb-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-bold text-muted small">Nome do Serviço</label>
                            <input asp-for="Name" type="text"
                                   maxlength="30"
                                   onkeypress="return (event.charCode >= 65 && event.charCode <= 90) || (event.charCode >= 97 && event.charCode <= 122) || (event.charCode >= 192 && event.charCode <= 255) || event.charCode == 32"
                                   title="Apenas letras e espaços são permitidos (máximo 30 caracteres)."
                                   class="form-control form-control-lg bg-light" placeholder="Ex: Corte de Cabelo" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label fw-bold text-muted small">Categoria</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select form-select-lg bg-light" required>
                                <option value="">Selecione uma categoria...</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label fw-bold text-muted small">Preço (R$)</label>
                            <input asp-for="Price" type="number" step="0.01" min="0" class="form-control form-control-lg bg-light" placeholder="0,00" required />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DurationMinutes" class="form-label fw-bold text-muted small">Duração (Minutos)</label>
                            <input asp-for="DurationMinutes" type="number"
                                   min="1" max="9999"
                                   onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                                   oninput="if(this.value.length > 4) this.value = this.value.slice(0, 4);"
                                   title="Apenas números (máximo 4 dígitos)."
                                   class="form-control form-control-lg bg-light" placeholder="Ex: 30" required />
                            <span asp-validation-for="DurationMinutes" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-bold text-muted small">Descrição do Serviço</label>
                            <textarea asp-for="Description" class="form-control form-control-lg bg-light" rows="3" placeholder="Detalhe o que está incluído no serviço..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr class="my-5 text-muted" />

                    <div class="d-flex justify-content-end gap-3">
                        <a asp-controller="Dashboard" asp-action="DashboardProfissional" class="btn btn-light fw-bold px-4 py-2 border">Cancelar</a>
                        <button type="submit" class="btn text-white fw-bold px-4 py-2" style="background: var(--ds-primary, #00236f); border-radius: 0.5rem;">
                            Salvar Serviço
                        </button>
                    </div>
                </form>
                <hr class="my-5 text-muted" />

                <div class="mb-4 d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined fs-3" style="color: #00236f;">list_alt</span>
                    <h3 class="h4 fw-bold mb-0" style="color: #00236f;">Meus Serviços Cadastrados</h3>
                </div>

                @if (ViewBag.MeusServicos != null && ((IEnumerable<SistemaAgendamentoWebII.Models.Service>)ViewBag.MeusServicos).Any())
                {
                    <div class="card shadow-sm border-0" style="border-radius: 1.25rem;">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light text-secondary small text-uppercase fw-bold border-0">
                                    <tr>
                                        <th class="ps-4 py-3 w-25">Nome do Serviço</th>
                                        <th class="w-25">Descrição</th>
                                        <th>Duração</th>
                                        <th>Preço</th>
                                        <th class="text-center pe-4">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in ViewBag.MeusServicos)
                                    {
                                        <tr>
                                            <td class="fw-semibold text-dark ps-4">@item.Name</td>

                                            <td class="text-muted small text-truncate" style="max-width: 200px;" title="@item.Description">
                                                @(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)
                                            </td>

                                            <td class="text-muted">⏱ @item.DurationMinutes min</td>
                                            <td class="text-success fw-bold">R$ @item.Price.ToString("F2")</td>
                                            <td class="text-center pe-4">
                                                <span class="badge py-1.5 px-3 rounded-pill bg-success-subtle text-success">
                                                    Ativo
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card shadow-sm border-0 bg-light" style="border-radius: 1.25rem;">
                        <div class="card-body text-center py-5">
                            <span class="material-symbols-outlined text-muted mb-2" style="font-size: 3rem;">inventory_2</span>
                            <h4 class="h5 fw-bold text-muted mb-1">Nenhum serviço cadastrado</h4>
                            <p class="text-muted mb-0">Preencha o formulário acima para adicionar o seu primeiro serviço.</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>